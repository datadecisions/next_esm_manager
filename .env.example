# Copy to .env.local and set your API URL.
# Local dev: http://localhost:3001 (ESM server)
# Production: https://api.datadecisions.net or https://yourdomain.com/api
NEXT_PUBLIC_API_URL=http://localhost:3001

# Optional: app origin for PDF generation (print API). Defaults to request.nextUrl.origin.
# Set in production if the API is behind a proxy or different host (e.g. https://app.example.com).
# NEXT_PUBLIC_APP_URL=http://localhost:3000
